# ================================
# EVOLUTION API
# ================================
EVOLUTION_API_URL=https://tu-servidor:8080
EVOLUTION_API_KEY=tu-api-key-aqui
EVOLUTION_INSTANCE=nombre-instancia
MEYER_INSTANCIA=peluqueria-beta

# ================================
# GOOGLE (Service Account)
# ================================
# Ruta al archivo JSON descargado de Google Cloud
# NUNCA subir el JSON a Git — va en secrets/
GOOGLE_CREDENTIALS_PATH=./secrets/google-credentials.json
GOOGLE_SHEET_ID=id-de-tu-google-sheet

# Google Calendar (opcional - actualmente deshabilitado)
GOOGLE_CALENDAR_ID=id-calendario@group.calendar.google.com

# ================================
# ANTHROPIC
# ================================
# Nota: la key está configurada directamente en n8n como credencial
# Si algún día se usa fuera de n8n, agregarla aquí
ANTHROPIC_API_KEY=sk-ant-api03-...

# ================================
# PELUQUERÍA MEYER
# ================================
# Número del dueño para notificaciones de nuevas citas
MEYER_NUMERO_DUENO=573XXXXXXXXX

# ================================
# n8n
# ================================
N8N_URL=https://n8n.zyvenshop.com
# Webhooks son públicos — no requieren token adicional

# Permitir acceso a variables de entorno desde nodos (requerido para usar process.env)
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
