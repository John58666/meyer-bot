{
  "name": "No-Shows - Auto Completar",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyDay",
              "hour": 23,
              "minute": 59
            }
          ]
        }
      },
      "id": "26dae46e-bd1e-4542-ac7d-22ea1c274429",
